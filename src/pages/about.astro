---
import BaseLayout from "../layouts/BaseLayout.astro";
import { clinic } from "../config/clinic";

const pageTitle = `About Us | ${clinic.name} - ${clinic.address.area}`;
const pageDescription = `Learn about ${clinic.name}, established in ${clinic.established}. Our mission, team, and commitment to quality healthcare in ${clinic.address.area}.`;

const base = import.meta.env.BASE_URL;
const galleryImages = [
  { src: `${base}images/gallery-1.jpg`, alt: "Modern clinic reception area" },
  { src: `${base}images/gallery-2.jpg`, alt: "State-of-the-art treatment room" },
  { src: `${base}images/gallery-3.jpg`, alt: "Sterilization and hygiene protocols" },
  { src: `${base}images/gallery-4.jpg`, alt: "Comfortable waiting area" },
];

const certifications = [
  "Indian Dental Association Member",
  "ISO 9001:2015 Certified",
  "BIS-Certified Sterilization Protocols",
  "Digital X-Ray & CBCT Imaging",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-primary/5 via-white to-primary/10 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-sm font-semibold text-primary uppercase tracking-wider mb-3">About Us</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-text mb-4 animate-fade-in">
          Our Story
        </h1>
        <p class="text-lg text-text-muted leading-relaxed animate-fade-in" style="animation-delay: 0.1s;">
          Delivering quality healthcare to the community since {clinic.established}.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-text mb-6">
            Welcome to {clinic.name}
          </h2>
          <div class="space-y-4 text-text-muted leading-relaxed">
            <p>
              Founded in {clinic.established}, {clinic.name} has been a trusted name in dental care in {clinic.address.area}. 
              What started as a small practice has grown into a comprehensive dental care center, serving over 
              <span class="font-semibold text-primary">{clinic.stats.patientsServed}</span> patients with dedication and compassion.
            </p>
            <p>
              Our clinic is equipped with the latest dental technology, from digital X-rays to advanced implant systems. 
              We believe that every patient deserves access to world-class dental care at affordable prices, and that's 
              exactly what we deliver — day after day.
            </p>
            <p>
              Our team of experienced dentists brings together decades of combined expertise across general dentistry, 
              orthodontics, prosthodontics, and cosmetic procedures. We take pride in our patient-first approach, 
              transparent pricing, and a welcoming atmosphere that puts even the most anxious patients at ease.
            </p>
          </div>
        </div>
        <div class="relative">
          <img
            src={`${import.meta.env.BASE_URL}images/about-clinic.jpg`}
            alt={`${clinic.name} - Clinic interior`}
            class="w-full rounded-2xl shadow-xl object-cover aspect-[4/3]"
            width="640"
            height="480"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-primary text-white rounded-2xl p-6 shadow-xl hidden md:block">
            <p class="text-3xl font-bold font-heading">{clinic.stats.yearsExperience}</p>
            <p class="text-primary-light/80 text-sm">Years of Excellence</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 md:py-24 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block text-sm font-semibold text-primary uppercase tracking-wider mb-3">Our Mission</span>
        <h2 class="text-2xl md:text-3xl lg:text-4xl font-heading font-bold text-text mb-6">
          Healthier Smiles, Happier Lives
        </h2>
        <p class="text-lg text-text-muted leading-relaxed mb-8">
          Our mission is to provide accessible, high-quality dental care using modern technology and evidence-based practices. 
          We aim to make every patient's experience comfortable, transparent, and transformative — because everyone deserves 
          a smile they're proud of.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-text mb-1">Patient First</h3>
            <p class="text-sm text-text-muted">Your comfort and care are our top priority</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-text mb-1">Innovation</h3>
            <p class="text-sm text-text-muted">Latest technology for better outcomes</p>
          </div>
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mx-auto mb-3">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-text mb-1">Affordability</h3>
            <p class="text-sm text-text-muted">Quality care at transparent prices</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications -->
  <section class="py-16 md:py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-block text-sm font-semibold text-primary uppercase tracking-wider mb-2">Certifications & Standards</span>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-text">
          Quality You Can Trust
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-4xl mx-auto stagger-children">
        {certifications.map((cert) => (
          <div class="flex items-center gap-3 bg-surface-alt rounded-xl p-4 border border-border">
            <svg class="w-6 h-6 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-sm font-medium text-text">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Photo Gallery -->
  <section class="py-16 md:py-24 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <span class="inline-block text-sm font-semibold text-primary uppercase tracking-wider mb-2">Gallery</span>
        <h2 class="text-2xl md:text-3xl font-heading font-bold text-text">
          Our Clinic
        </h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 stagger-children">
        {galleryImages.map((img) => (
          <div class="rounded-xl overflow-hidden group">
            <img
              src={img.src}
              alt={img.alt}
              class="w-full h-48 md:h-56 object-cover group-hover:scale-105 transition-transform duration-500"
              width="300"
              height="224"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-4">
        Ready to Experience Better Dental Care?
      </h2>
      <p class="text-primary-light/80 mb-8 max-w-xl mx-auto">
        Book your appointment today and join the thousands of families who trust us with their smiles.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`${import.meta.env.BASE_URL}#appointment`}
          class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-7 py-3.5 rounded-xl hover:bg-gray-50 transition-colors"
        >
          Book Appointment
        </a>
        <a
          href={`https://wa.me/${clinic.whatsapp}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold px-7 py-3.5 rounded-xl transition-colors"
        >
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
