---
import { clinic } from "../config/clinic";

const currentYear = new Date().getFullYear();
const hasSocial = clinic.social.instagram || clinic.social.facebook || clinic.social.youtube;
const base = import.meta.env.BASE_URL;

const footerLinks = [
  { href: base, label: "Home" },
  { href: `${base}about`, label: "About Us" },
  { href: `${base}services`, label: "Services" },
  { href: `${base}doctors`, label: "Our Doctors" },
  { href: `${base}contact`, label: "Contact" },
];
---

<footer class="bg-gradient-to-b from-gray-900 to-gray-950 text-gray-300">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href={base} class="inline-block mb-4">
          <span class="text-2xl font-bold font-heading text-white">{clinic.brand.logoText}</span>
        </a>
        <p class="text-sm text-gray-400 leading-relaxed mb-6">
          {clinic.tagline}. Serving the community since {clinic.established}.
        </p>
        <!-- Google Rating Badge -->
        <div class="flex items-center gap-2 bg-white/5 rounded-xl px-4 py-3 w-fit">
          <div class="flex items-center gap-0.5">
            {[1,2,3,4,5].map((star) => (
              <svg class={`w-4 h-4 ${star <= Math.round(parseFloat(clinic.stats.googleRating)) ? 'text-accent' : 'text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <span class="text-white font-semibold text-sm">{clinic.stats.googleRating}</span>
          <span class="text-gray-500 text-xs">({clinic.stats.googleReviews} reviews)</span>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200 flex items-center gap-2">
                <svg class="w-3 h-3 text-primary-light" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-light shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-gray-400">
              {clinic.address.line1},<br />{clinic.address.line2},<br />{clinic.address.area} - {clinic.address.pincode}
            </span>
          </li>
          <li>
            <a href={`tel:${clinic.phone}`} class="flex items-center gap-3 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-5 h-5 text-primary-light shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {clinic.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${clinic.email}`} class="flex items-center gap-3 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-5 h-5 text-primary-light shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {clinic.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Hours -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Clinic Hours</h3>
        <ul class="space-y-3">
          {clinic.hours.map((h) => (
            <li class="flex justify-between items-center text-sm bg-white/5 rounded-lg px-4 py-2.5">
              <span class="text-gray-300 font-medium">{h.day}</span>
              <span class="text-gray-400">{h.time}</span>
            </li>
          ))}
        </ul>

        {hasSocial && (
          <div class="mt-6">
            <h4 class="text-white font-semibold text-sm uppercase tracking-wider mb-3">Follow Us</h4>
            <div class="flex items-center gap-3">
              {clinic.social.instagram && (
                <a href={clinic.social.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center transition-colors" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
              )}
              {clinic.social.facebook && (
                <a href={clinic.social.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center transition-colors" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              )}
              {clinic.social.youtube && (
                <a href={clinic.social.youtube} target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 flex items-center justify-center transition-colors" aria-label="YouTube">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-gray-500">
        &copy; {currentYear} {clinic.name}. All rights reserved.
      </p>
      <p class="text-xs text-gray-600">
        Designed with care for better healthcare
      </p>
    </div>
  </div>
</footer>
