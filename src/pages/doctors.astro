---
import BaseLayout from "../layouts/BaseLayout.astro";
import DoctorCard from "../components/DoctorCard.astro";
import { clinic } from "../config/clinic";

const pageTitle = `Our Doctors | ${clinic.name} - ${clinic.address.area}`;
const pageDescription = `Meet our experienced team of dental professionals at ${clinic.name}. ${clinic.doctors.map(d => d.name).join(", ")} — qualified, caring, and dedicated to your oral health.`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-primary/5 via-white to-primary/10 py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="inline-block text-sm font-semibold text-primary uppercase tracking-wider mb-3">Our Team</span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-text mb-4 animate-fade-in">
          Meet Our Doctors
        </h1>
        <p class="text-lg text-text-muted leading-relaxed animate-fade-in" style="animation-delay: 0.1s;">
          Our team of experienced dental professionals is dedicated to providing you with the 
          highest quality care in a warm and welcoming environment.
        </p>
      </div>
    </div>
  </section>

  <!-- All Doctors -->
  <section class="py-16 md:py-24 bg-surface">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12">
        {clinic.doctors.map((doctor, index) => (
          <div class={`grid grid-cols-1 lg:grid-cols-5 gap-8 lg:gap-12 items-start ${index > 0 ? 'pt-12 border-t border-border' : ''}`}>
            {/* Photo */}
            <div class="lg:col-span-2">
              <div class="rounded-2xl overflow-hidden shadow-lg">
                <img
                  src={doctor.photo}
                  alt={`${doctor.name} - ${doctor.qualifications}`}
                  class="w-full object-cover object-top aspect-[3/4]"
                  width="400"
                  height="533"
                  loading="lazy"
                />
              </div>
            </div>

            {/* Info */}
            <div class="lg:col-span-3">
              <h2 class="text-2xl md:text-3xl font-heading font-bold text-text mb-1">
                {doctor.name}
              </h2>
              <p class="text-primary font-semibold mb-4">{doctor.qualifications}</p>

              <div class="flex items-center gap-4 mb-6">
                <span class="inline-flex items-center gap-1.5 bg-primary/10 text-primary text-sm font-medium px-3 py-1.5 rounded-full">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  {doctor.experience} Experience
                </span>
              </div>

              <p class="text-text-muted leading-relaxed mb-6">{doctor.bio}</p>

              {/* Specializations */}
              {doctor.specializations && doctor.specializations.length > 0 && (
                <div class="mb-6">
                  <h3 class="text-sm font-semibold text-text uppercase tracking-wider mb-3">Specializations</h3>
                  <div class="flex flex-wrap gap-2">
                    {doctor.specializations.map((spec) => (
                      <span class="text-sm bg-primary/8 text-primary font-medium px-3 py-1.5 rounded-full">
                        {spec}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              {/* Languages */}
              {doctor.languages && doctor.languages.length > 0 && (
                <div class="flex items-center gap-2 text-sm text-text-muted">
                  <svg class="w-5 h-5 text-text-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                  </svg>
                  <span>Speaks: <span class="font-medium text-text">{doctor.languages.join(", ")}</span></span>
                </div>
              )}

              {/* Book with doctor */}
              <div class="mt-8">
                <a
                  href={`https://wa.me/${clinic.whatsapp}?text=${encodeURIComponent(`Hi, I'd like to book an appointment with ${doctor.name}.`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-whatsapp hover:bg-whatsapp-dark text-white font-semibold px-6 py-3 rounded-xl transition-colors"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                  </svg>
                  Book with {doctor.name.split(" ")[0]}. {doctor.name.split(" ").slice(1).join(" ")}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-primary">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-4">
        Ready to Meet Our Team?
      </h2>
      <p class="text-primary-light/80 mb-8">
        Book your appointment today and experience the difference expert care makes.
      </p>
      <a
        href="/#appointment"
        class="inline-flex items-center justify-center gap-2 bg-white text-primary font-semibold px-7 py-3.5 rounded-xl hover:bg-gray-50 transition-colors"
      >
        Book Appointment
      </a>
    </div>
  </section>
</BaseLayout>
